# PostgreSQL — local Docker (npm run db:up) or Neon / Supabase
DATABASE_URL="postgresql://omnipost:omnipost@localhost:5432/omnipost?schema=public"

# NextAuth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-secure-random-string"
AUTH_URL="http://localhost:3000"

# OpenAI — content generation (required for real AI; omit to use fallback rules)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Twitter / X API v2 — OAuth 2.0 user access token with tweet.write scope
# https://developer.x.com/en/docs/authentication/oauth-2-0/user-access-token
TWITTER_ACCESS_TOKEN=""
TWITTER_USERNAME=""
TWITTER_USER_ID=""

# LinkedIn Marketing / Share API — member UGC posts
# https://learn.microsoft.com/en-us/linkedin/marketing/community-management/shares/ugc-post-api
LINKEDIN_ACCESS_TOKEN=""
LINKEDIN_PERSON_URN="urn:li:person:YOUR_ID"
LINKEDIN_ACCOUNT_NAME=""

# Optional: OAuth providers for NextAuth
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
